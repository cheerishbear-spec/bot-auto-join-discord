# ===== Telegram =====
# Dapetin dari https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Username public channel target (tanpa @), contoh: discordinvites
TELEGRAM_CHANNEL=

# Session string Telegram. Kosongkan pas pertama kali run, nanti script minta login
# lewat nomor HP + OTP, terus output string yg harus ditaruh di sini biar ga login ulang.
TELEGRAM_SESSION=

# ===== Discord =====
# User token akun lo (BUKAN bot token). Ambil dari DevTools > Network > header Authorization
# JANGAN share ini ke siapapun.
DISCORD_TOKEN=

# ===== Sniper =====
# Delay random sebelum join (ms)
JOIN_DELAY_MIN_MS=2000
JOIN_DELAY_MAX_MS=3000
